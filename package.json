{
  "name": "vscode-tokencount",
  "displayName": "Token Count",
  "description": "Show token count for the active file in the VS Code status bar",
  "version": "0.0.1",
  "publisher": "local-dev",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tokenCount.toggleDetails",
        "title": "Token Count: Toggle Detailed Information"
      },
      {
        "command": "tokenCount.pickCounterSource",
        "title": "Token Count: Choose Counter Source"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Token Count",
      "properties": {
        "tokenCount.countingMode": {
          "type": "string",
          "default": "encoding",
          "enum": [
            "encoding",
            "model"
          ],
          "description": "Choose whether token counts use a direct encoding or a model mapping."
        },
        "tokenCount.encoding": {
          "type": "string",
          "default": "cl100k_base",
          "description": "tiktoken encoding to use for token counting (for example: cl100k_base, o200k_base, p50k_base)."
        },
        "tokenCount.model": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "Model name to use when countingMode is model (for example: gpt-4o-mini, gpt-4.1-mini, o4-mini)."
        },
        "tokenCount.displayOnRightSide": {
          "type": "boolean",
          "default": false,
          "description": "Display token count on the right side of the status bar."
        },
        "tokenCount.showForUntitled": {
          "type": "boolean",
          "default": true,
          "description": "Show token count for untitled editors."
        }
      }
    }
  },
  "scripts": {
    "clean": "rimraf dist .vscode-test",
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -p ./tsconfig.json --watch",
    "lint": "eslint . --ext .ts",
    "pretest": "npm run compile && npm run lint",
    "test": "mocha \"dist/test/**/*.test.js\" --timeout 5000"
  },
  "keywords": [
    "tokens",
    "tiktoken",
    "statusbar",
    "llm"
  ],
  "dependencies": {
    "tiktoken": "^1.0.22"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.2",
    "@types/vscode": "^1.110.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "mocha": "^11.7.5",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2"
  }
}
